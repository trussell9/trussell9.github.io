---
import Base from '../layouts/Base.astro';
import WorkCard from '../components/WorkCard.astro';
import { getCollection } from 'astro:content';

// Pull the featured case studies from the `work` collection and sort by `order`.
// Adding a new featured study later = drop in a Markdown file with featured: true.
const featured = (await getCollection('work', ({ data }) => data.featured)).sort(
	(a, b) => a.data.order - b.data.order,
);

// One piece of coverage as the home page's press hook. A single real headline is
// proof; the row of outlet names it replaced asked the reader to care about
// publications they may not know. Set `featured: true` on a different entry to
// swap it. Falls back to nothing rather than erroring if none is marked.
const featuredPress = (await getCollection('press')).find(({ data }) => data.featured);

// The four numbers that do the most work in the first screen. Three are the
// headline metric of a case study below, so the strip doubles as a table of
// contents for the work. The $2B is the exception and is worded carefully: it's
// PENN's number, not mine, and the claim is that the ecosystem work fed the
// strategy behind it, which is exactly what it was.
const stats = [
	{ value: '$3M', label: 'Year-over-year lift in live wagering' },
	{ value: '$2B', label: "theScore's exit; my ecosystem work fed the strategy" },
	{ value: '2', label: 'Platform rebrands, no live disruption' },
	{ value: '1.5M', label: 'Users on the app I rebuilt' },
];

// Skills shown as a single combined set of pills (no category groupings).
const skills = [
	'Product Strategy',
	'Roadmapping',
	'AI-Assisted Discovery',
	'A/B Testing',
	'Growth & Retention',
	'GTM & Launch Sequencing',
	'App Migrations',
	'Integrations & Ecosystem',
	'Cross-Functional Alignment',
];

// What I'm looking for, stated plainly. A recruiter's first question is whether
// there's a match at all, and making them infer it from prose costs both of us
// time. Deliberately specific: a vague answer here is the same as no answer.
const fit = [
	{ term: 'Roles', detail: 'Product Manager or Senior PM, as an individual contributor.' },
	{ term: 'Stage', detail: 'Roughly 50 to 1,000 people. Past scrappy, before bureaucratic.' },
	{
		term: 'Industries',
		detail:
			'Health, mobility, civic tech, and consumer products with genuine utility. Moving away from betting and iGaming.',
	},
	{
		term: 'What I value',
		detail:
			'Solving real problems for real people, at a company that means it. Product trio over handoffs: PM, engineering, and design deciding together.',
	},
	{
		term: 'In a manager',
		detail: 'Direct, transparent feedback and real investment in my growth. Coaching and autonomy, not a gatekeeper.',
	},
	{
		term: 'Location',
		detail: 'Toronto. Remote or hybrid across the US and Canada. Relocation for the right team and role.',
	},
];
---
<!-- `home` tells the shared rail to use same-page anchors (#about) rather than
     links back to the home page, and pairs with the scroll-spy script below.
     The rail and hub shell itself live in Base.astro, on every page. -->
<Base home>
	{/* The page's h1. It's visually hidden because the identity rail already states
	    the name and role in type — but a page with no h1 is a heading-structure and
	    SEO gap, and screen-reader "jump by heading" starts here. */}
	<h1 class="sr-only">Tim Russell — Product Manager</h1>

	<section id="about">
		<h2 class="section-title">About</h2>
		<div class="about">
			<p>I've spent my whole career at one company, theScore, and I'm proud of that. The tenure came from leadership handing me newer, bigger challenges, which are exactly the problems I like most.</p>
			<p>That's how I landed the projects at the centre of the company's strategy: rebuilding the Android app, then building the cross-app ecosystem between theScore's media and betting products, then steering that experience through an IPO, a $2B acquisition by PENN, and two U.S. platform migrations. Most recently I focused on theScore Bet, shipping live-betting features like in-app NFL streaming.</p>
			<p>Now I'm after the next hard problem, ideally a consumer product where solving it also makes a real difference to the people on the other side.</p>
		</div>

		{/* The prose says what I did; these say what it was worth. Sitting directly
		    under About, they close the paragraphs with evidence and lead into the
		    work. Same component as the case-study bands, so the numbers here and
		    the numbers on the studies read as one system. */}
		<dl class="metric-band metric-band--home">
			{stats.map((s) => (
				<div class="metric">
					<dt class="metric-value">{s.value}</dt>
					<dd class="metric-label">{s.label}</dd>
				</div>
			))}
		</dl>
	</section>

	<section id="work">
		<p class="section-title">Selected work</p>
		<h2>Turning strategic bets into shipped products.</h2>
		<p class="subhead" style="margin: 0.75rem 0 2rem;">Four projects across platform change, launches, and discovery.</p>
		<div class="work-grid">
			{featured.map((entry) => <WorkCard entry={entry} />)}
		</div>
		<p style="margin-top: 1.5rem;"><a href="/work">See all work →</a></p>
	</section>

	<section id="press">
		<p class="section-title">Press</p>
		<h2>In the news.</h2>
		<p class="subhead" style="margin: 0.75rem 0 1.5rem;">The products I've shipped have been covered across platform migrations, the Android rebuild, and the Ontario launch.</p>
		{featuredPress && (
			<div class="press-item">
				<h3 class="press-headline">{featuredPress.data.headline}</h3>
				<p class="press-blurb">{featuredPress.data.blurb}</p>
				<p class="press-source">
					{featuredPress.data.url ? (
						<a href={featuredPress.data.url} target="_blank" rel="noopener">{featuredPress.data.outlet}</a>
					) : (
						featuredPress.data.outlet
					)}
					{featuredPress.data.outlet && featuredPress.data.date && <span class="press-dot"> · </span>}
					{featuredPress.data.date}
				</p>
			</div>
		)}
		<p style="margin-top: 1.5rem;"><a href="/press">Read the coverage →</a></p>
	</section>

	<section id="skills">
		<h2 class="section-title">Skills</h2>
		<div class="skill-pills">
			{skills.map((s) => <span class="tag">{s}</span>)}
		</div>
	</section>

	{/* Stated plainly rather than buried in the Contact paragraph, where it used to
	    live. A recruiter's first question is whether there's a match at all. */}
	<section id="fit">
		<p class="section-title">Fit</p>
		<h2>What I'm looking for.</h2>
		<p class="subhead" style="margin: 0.75rem 0 1.5rem;">The short version, so you can tell in ten seconds whether we should talk.</p>
		<dl class="fit-list">
			{fit.map((f) => (
				<div class="fit-row">
					<dt class="fit-term">{f.term}</dt>
					<dd class="fit-detail">{f.detail}</dd>
				</div>
			))}
		</dl>
	</section>

	<section id="contact">
		<p class="section-title">Contact</p>
		<h2>Let's talk.</h2>
		<p class="subhead" style="margin: 0.75rem 0 1.5rem;">If any of that lines up, I'd like to hear about it. The best first step is an email.</p>
		<div class="cta">
			<a class="btn btn-primary" href="mailto:tim.russell57@gmail.com">Email me</a>
			<a class="btn btn-secondary" href="https://linkedin.com/in/timrrussell" target="_blank" rel="noopener">Connect on LinkedIn</a>
		</div>
		<div class="resume-cta" style="margin-top: 2rem;">
			<div>
				<p class="resume-cta-title">Prefer the résumé?</p>
				<p class="resume-cta-note">Two pages, with the detail behind each role.</p>
			</div>
			<a class="btn btn-primary" href="/Tim-Russell-Product-Manager.pdf" target="_blank" rel="noopener">View résumé</a>
		</div>
	</section>
	<!-- The scroll-spy that drives the rail's active state lives in Rail.astro,
	     so it survives client-side navigation back to this page. -->
</Base>
