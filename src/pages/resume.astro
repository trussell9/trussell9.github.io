---
import Base from '../layouts/Base.astro';
// Web résumé — summary-level mirror of the downloadable PDF in public/.
// Keep the two in sync: if the PDF changes, update this page to match.
---
<Base title="Résumé — Tim Russell" description="Tim Russell — Product Manager. 12 years at theScore / PENN Entertainment." active="resume">
	<section class="resume">
		<h1>Tim Russell</h1>
		<p class="subhead" style="margin-top: 0.5rem;">Product Manager · Toronto, Canada</p>
		{/* Keep the separator and both links on one line. Split across lines, the
		    compiler trims the trailing whitespace and "· LinkedIn" collapses to
		    "·LinkedIn". */}
		<p style="margin-top: 0.75rem;">
			<a href="mailto:tim.russell57@gmail.com">tim.russell57@gmail.com</a> <span style="color: var(--muted-foreground);">·</span> <a href="https://linkedin.com/in/timrrussell" target="_blank" rel="noopener">LinkedIn</a>
		</p>
		<p style="margin-top: 1rem; color: var(--muted-foreground);">6+ years in Product, 12 years total at theScore / PENN Entertainment. B2C mobile products across sports, media, and betting.</p>

		<div class="resume-cta">
			<div>
				<p class="resume-cta-title">Take the full résumé with you</p>
				<p class="resume-cta-note">Two pages, with the detail behind each role. The outline below is the short version.</p>
			</div>
			<a class="btn btn-primary" href="/Tim-Russell-Product-Manager.pdf" download>Download PDF</a>
		</div>

		<h2>Experience</h2>
		<div class="role">
			<h3>Product Manager — PENN Entertainment | theScore</h3>
			<p class="when">2022–2026</p>
			<p>Owned experiences connecting theScore's media and betting products across 20 U.S. and Canadian jurisdictions; moved to theScore Bet to focus on live betting and engagement.</p>
		</div>
		<div class="role">
			<h3>Associate Product Manager — theScore</h3>
			<p class="when">2020–2022</p>
			<p>Rebuilt theScore's Android app and helped build foundational cross-app experiences for theScore's entry into betting, spanning the company's $186M IPO and $2B acquisition by PENN.</p>
		</div>
		<div class="role">
			<h3>Operations Manager — theScore</h3>
			<p class="when">2014–2020</p>
			<p>Led customer service and operations; owned the data partnerships powering theScore for 4M+ monthly active users.</p>
		</div>

		<h2>Skills</h2>
		<p>Product Strategy · Roadmapping · Integrations &amp; Ecosystem · App Migrations · AI-Assisted Discovery · A/B Testing · GTM &amp; Launch Sequencing · Cross-Functional Alignment · Growth &amp; Retention</p>

		<h2>Education</h2>
		<p>Advanced Product Management Certificate — Product Faculty (2021)<br />Bachelor of Journalism — Toronto Metropolitan University (2010)</p>

		<div class="resume-cta" style="margin-top: 2.5rem;">
			<div>
				<p class="resume-cta-title">Want the detail?</p>
				<p class="resume-cta-note">The PDF has the accomplishments and metrics behind each role.</p>
			</div>
			<a class="btn btn-primary" href="/Tim-Russell-Product-Manager.pdf" download>Download PDF</a>
		</div>

	</section>
</Base>
