---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
// <Image> emits width/height (so the page doesn't jump as it loads), converts to
// a modern format, and generates the responsive sizes listed below.
import { Image } from 'astro:assets';

// getStaticPaths tells Astro which /work/[slug] pages to build — one per entry.
// This runs at build time; each page is pre-rendered to static HTML.
export async function getStaticPaths() {
	const entries = await getCollection('work');
	return entries.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
// render() turns the Markdown body into a <Content /> component we can drop in.
const { Content } = await render(entry);
const { title, summary, role, timeframe, team, skills, metrics, cover, coverAlt } = entry.data;
---
<Base title={`${title} — Tim Russell`} description={summary} active="work">
	<article class="case-study">
		<a class="back-link" href="/work">← All work</a>
		<h1>{title}</h1>
		<p class="subhead" style="margin-top: 1rem;">{summary}</p>

		<div class="meta">
			<span>{role}</span>
			<span>· {timeframe}</span>
			<span>· {team}</span>
		</div>
		<div class="meta" style="margin-top: 0.5rem;">
			{skills.map((s) => <span class="tag">{s}</span>)}
		</div>

		{/* Outcomes first. A PM portfolio is read for its numbers, and buried in
		    prose they're something the reader has to hunt for. A <dl> because each
		    one really is a term and its definition, not a list of unrelated items. */}
		{metrics.length > 0 && (
			<dl class="metric-band">
				{metrics.map((m) => (
					<div class="metric">
						<dt class="metric-value">{m.value}</dt>
						<dd class="metric-label">{m.label}</dd>
					</div>
				))}
			</dl>
		)}

		{cover && (
			<figure class="case-cover">
				<Image src={cover} alt={coverAlt!} widths={[400, 800, 1200]} sizes="(max-width: 900px) 100vw, 656px" />
			</figure>
		)}

		<div class="prose" style="margin-top: 2rem;">
			<Content />
		</div>
	</article>
</Base>
