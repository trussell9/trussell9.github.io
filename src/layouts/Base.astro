---
// Base.astro — the shared layout every page reuses.
// Frontmatter (between the --- fences) runs at BUILD time only.
// Fonts are self-hosted (@fontsource) rather than fetched from Google: no
// third-party request on every visit, no swap flash while the CSS round-trips,
// and nothing about the site depends on someone else's CDN staying up. The
// weights below are exactly the ones global.css asks for — adding a weight to a
// rule means adding its import here too, or the browser will fake it.
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/600.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/dm-sans/400.css';
import '@fontsource/dm-sans/500.css';
import '@fontsource/dm-sans/700.css';
import '../styles/global.css';
import Rail from '../components/Rail.astro';
import { ClientRouter } from 'astro:transitions';

// Props a page can pass in. All have sensible defaults so a page can set
// none, some, or all. `title` shows in the browser tab + OG; `description`
// feeds the meta description + OG (recruiter discoverability).
interface Props {
	title?: string;
	description?: string;
	// `home` switches the rail's section links between same-page anchors and
	// links back to the home page. `active` marks the current nav item.
	home?: boolean;
	active?: string;
}
const {
	title = "Tim Russell — Product Manager",
	description = "Product manager who kept a B2C betting product shipping through two platform migrations, an IPO, and a $2B acquisition — case studies from theScore and PENN Entertainment.",
	home = false,
	active,
} = Astro.props;

// Absolute canonical URL for this page, built from `site` in astro.config.mjs.
const canonical = new URL(Astro.url.pathname, Astro.site);
// Social preview card. Must be an absolute URL — LinkedIn and Slack fetch it
// from their own servers, where a relative path resolves to nothing.
// Regenerate with scripts/make-og.py if the copy or the tokens change.
const ogImage = new URL('/og.png', Astro.site);
---
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />

		<!-- Open Graph (link previews on LinkedIn/Slack/etc.) -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonical} />
		<meta property="og:site_name" content="Tim Russell" />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="Tim Russell, Product Manager — I ship consumer products through the hard parts." />
		<meta name="twitter:card" content="summary_large_image" />

		{/* Structured data, home page only — one Person per site, or search engines
		    see the same entity described five times. Tells Google which name, role
		    and profiles belong to this site rather than inferring them from copy. */}
		{home && (
			<script
				type="application/ld+json"
				set:html={JSON.stringify({
					'@context': 'https://schema.org',
					'@type': 'Person',
					name: 'Tim Russell',
					jobTitle: 'Product Manager',
					url: Astro.site?.href,
					image: ogImage.href,
					email: 'mailto:tim.russell57@gmail.com',
					address: { '@type': 'PostalAddress', addressLocality: 'Toronto', addressCountry: 'CA' },
					sameAs: ['https://linkedin.com/in/timrrussell'],
					alumniOf: { '@type': 'CollegeOrUniversity', name: 'Toronto Metropolitan University' },
				})}
			/>
		)}

		<!-- Client-side routing: swap just the changed part of the document instead
		     of tearing down and rebuilding the whole page on every navigation.
		     Without it the rail is destroyed and re-created on each click. -->
		<ClientRouter />
	</head>
	<body>
		<!-- Split hub on every page: a sticky left identity rail beside a scrolling
		     content column, so navigation never changes shape between pages. -->
		<div class:list={['hub', !home && 'hub--sub']}>
			<Rail home={home} active={active} />
			<main class="hub-content">
				<!-- Whatever a page puts between <Base> and </Base> renders here. -->
				<slot />
			</main>
		</div>
	</body>
</html>
